# Copy to env/default.env and fill your own keys.
# IMPORTANT: do NOT commit env/default.env (it's in .gitignore).

# ===== Providers =====
# Cloubic proxy (for provider=cloubic)
CLOUBIC_API_KEY=""

# Official Google Gemini (for provider=official)
GEMINI_API_KEY=""

# DashScope (for TTS / voice cloning)
DASHSCOPE_API_KEY=""

# ===== Optional: OSS upload (only needed by some debug helpers; safe to leave empty if you don't use them) =====
ALIYUN_ACCESS_KEY=""
ALIYUN_ACCESS_SECRET=""
ALIYUN_BUCKET_NAME=""
ALIYUN_BUCKET_ENDPORT="https://oss-cn-hangzhou.aliyuncs.com"

